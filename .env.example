# Upstream API configuration
CODEX_ROUTER_UPSTREAM__BASE_URL=https://api.deepseek.com/v1
CODEX_ROUTER_UPSTREAM__API_KEY=your-api-key-here
CODEX_ROUTER_UPSTREAM__TIMEOUT=120

# Server configuration
CODEX_ROUTER_SERVER__HOST=127.0.0.1
CODEX_ROUTER_SERVER__PORT=8080

# Model name override (optional): map requested model to a different one
# CODEX_ROUTER_MODEL_OVERRIDE=deepseek-chat

# Pass through the client's API key to upstream instead of using UPSTREAM__API_KEY
# CODEX_ROUTER_PASSTHROUGH_API_KEY=false
