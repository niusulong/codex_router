# Codex Router 环境变量配置示例
# 所有变量前缀为 CODEX_ROUTER_，嵌套分隔符为 __

# 上游 API 配置
CODEX_ROUTER_UPSTREAM__BASE_URL=https://api.example.com/v1
CODEX_ROUTER_UPSTREAM__API_KEY=your-api-key-here
CODEX_ROUTER_UPSTREAM__TIMEOUT=120

# 服务器配置
CODEX_ROUTER_SERVER__HOST=127.0.0.1
CODEX_ROUTER_SERVER__PORT=8080
CODEX_ROUTER_SERVER__LOG_LEVEL=info

# 模型名称覆盖（可选）
# CODEX_ROUTER_MODEL_OVERRIDE=deepseek-chat

# 是否透传客户端 API Key（默认 false）
# CODEX_ROUTER_PASSTHROUGH_API_KEY=false

# Codex CLI 配置管理
CODEX_ROUTER_CODEX__AUTO_CONFIGURE=true
# CODEX_ROUTER_CODEX__CONFIG_DIR=~/.codex