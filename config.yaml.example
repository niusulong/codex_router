# Codex Router 配置文件

upstream:
  # 上游 API 基础地址（Chat Completions 兼容服务）
  base_url: "https://api.example.com/v1"
  # 上游 API Key
  api_key: "your-api-key-here"
  # 请求超时（秒）
  timeout: 120
  # 上游 API 格式: openai (Chat Completions) 或 anthropic (Messages API)
  # api_format: "openai"

server:
  # 代理监听地址
  host: "127.0.0.1"
  # 代理监听端口
  port: 8080
  log_level: "info"

# 模型名称覆盖（可选）：将请求中的模型名替换为此值
# model_override: "your-model-name"

# 是否将客户端的 API Key 透传给上游（当 upstream.api_key 为空时生效）
passthrough_api_key: false

# 需要过滤的 Responses API 内置工具类型
ignored_builtin_tools:
  - web_search_preview
  - web_search
  - file_search
  - code_interpreter
  - mcp

# Codex CLI 配置管理
codex:
  # 是否在启动时自动配置 Codex CLI（修改 ~/.codex/auth.json）
  auto_configure: true
  # Codex 配置目录（默认 ~/.codex）
  config_dir: null

# 模型预设（可选）：预定义多套上游配置，通过 Web 管理面板一键切换
# 支持同时配置 OpenAI 格式和 Anthropic 格式的预设
# presets:
#   - name: "DeepSeek"
#     base_url: "https://api.deepseek.com/v1"
#     api_key: "sk-xxx"
#     model: "deepseek-chat"
#     timeout: 120
#     # api_format: "openai"  # 默认为 openai
#   - name: "Qwen"
#     base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
#     api_key: "sk-yyy"
#     model: "qwen-plus"
#     timeout: 120
#   - name: "Claude"
#     base_url: "https://api.anthropic.com"
#     api_key: "sk-ant-zzz"
#     model: "claude-sonnet-4-20250514"
#     api_format: "anthropic"
#     timeout: 120
# active_preset: "DeepSeek"
